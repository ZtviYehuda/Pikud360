# --- PostgreSQL Database Configuration ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pass_123
POSTGRES_DB=pikud360_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Backend Flask Configuration ---
FLASK_APP=backend/run.py
FLASK_ENV=development
SECRET_KEY=change_this_to_a_secure_random_hex_key_in_production
JWT_SECRET_KEY=change_this_to_another_secure_random_hex_key_in_production
PORT=5000

# Connection pool settings
DB_MIN_CONNECTIONS=1
DB_MAX_CONNECTIONS=10

# --- Frontend Configuration ---
VITE_API_URL=http://localhost:5000
